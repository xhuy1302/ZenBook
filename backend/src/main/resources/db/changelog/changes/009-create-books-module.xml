<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

    <changeSet id="20260405-create-books-full-module" author="zenbook">

        <createTable tableName="tags">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="slug" type="VARCHAR(100)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="description" type="VARCHAR(255)"/>
            <column name="color" type="VARCHAR(20)"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="deleted_at" type="TIMESTAMP"/>
        </createTable>

        <createTable tableName="books">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="slug" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="isbn" type="VARCHAR(50)">
                <constraints unique="true"/>
            </column>
            <column name="description" type="LONGTEXT"/>
            <column name="original_price" type="DOUBLE">
                <constraints nullable="false"/>
            </column>
            <column name="sale_price" type="DOUBLE">
                <constraints nullable="false"/>
            </column>
            <column name="stock_quantity" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="sold_quantity" type="INT" defaultValueNumeric="0"/>
            <column name="thumbnail" type="VARCHAR(500)"/>
            <column name="status" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>

            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="deleted_at" type="TIMESTAMP"/>
        </createTable>

        <createTable tableName="book_specifications">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="book_id" type="VARCHAR(36)">
                <constraints nullable="false" unique="true" foreignKeyName="fk_specs_book" references="books(id)" deleteCascade="true"/>
            </column>
            <column name="format" type="VARCHAR(50)"/>
            <column name="page_count" type="INT"/>
            <column name="publication_year" type="INT"/>
            <column name="dimensions" type="VARCHAR(100)"/>
            <column name="weight" type="INT"/>
            <column name="language" type="VARCHAR(50)"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="deleted_at" type="TIMESTAMP"/>
        </createTable>

        <createTable tableName="book_images">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="book_id" type="VARCHAR(36)">
                <constraints nullable="false" foreignKeyName="fk_images_book" references="books(id)" deleteCascade="true"/>
            </column>
            <column name="image_url" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="display_order" type="INT" defaultValueNumeric="0"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="deleted_at" type="TIMESTAMP"/>
        </createTable>

        <createTable tableName="book_categories">
            <column name="book_id" type="VARCHAR(36)">
                <constraints nullable="false" foreignKeyName="fk_bc_book" references="books(id)" deleteCascade="true"/>
            </column>
            <column name="category_id" type="VARCHAR(36)">
                <constraints nullable="false" foreignKeyName="fk_bc_category" references="categories(id)" deleteCascade="true"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="book_categories" columnNames="book_id, category_id" constraintName="pk_book_categories"/>

        <createTable tableName="book_authors">
            <column name="book_id" type="VARCHAR(36)">
                <constraints nullable="false" foreignKeyName="fk_ba_book" references="books(id)" deleteCascade="true"/>
            </column>
            <column name="author_id" type="VARCHAR(36)">
                <constraints nullable="false" foreignKeyName="fk_ba_author" references="authors(id)" deleteCascade="true"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="book_authors" columnNames="book_id, author_id" constraintName="pk_book_authors"/>

        <createTable tableName="book_tags">
            <column name="book_id" type="VARCHAR(36)">
                <constraints nullable="false" foreignKeyName="fk_bt_book" references="books(id)" deleteCascade="true"/>
            </column>
            <column name="tag_id" type="VARCHAR(36)">
                <constraints nullable="false" foreignKeyName="fk_bt_tag" references="tags(id)" deleteCascade="true"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="book_tags" columnNames="book_id, tag_id" constraintName="pk_book_tags"/>

    </changeSet>
</databaseChangeLog>
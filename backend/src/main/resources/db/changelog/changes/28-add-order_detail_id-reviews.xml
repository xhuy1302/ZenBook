<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

<changeSet id="add-order-detail-id-to-reviews" author="your-name">
    <addColumn tableName="reviews">
        <column name="order_detail_id" type="VARCHAR(36)"/>
    </addColumn>

    <addForeignKeyConstraint baseTableName="reviews"
                             baseColumnNames="order_detail_id"
                             constraintName="fk_reviews_order_details"
                             referencedTableName="order_details"
                             referencedColumnNames="id"/>
</changeSet>
</databaseChangeLog>
<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="add-ghn-ids-to-user-addresses" author="xuanhuy">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="user_addresses" columnName="district_id"/>
            </not>
        </preConditions>

        <addColumn tableName="user_addresses">
            <column name="district_id" type="INT" remarks="Mã Quận/Huyện của Giao Hàng Nhanh"/>
            <column name="ward_code" type="VARCHAR(50)" remarks="Mã Phường/Xã của Giao Hàng Nhanh"/>
        </addColumn>

        <rollback>
            <dropColumn tableName="user_addresses" columnName="district_id"/>
            <dropColumn tableName="user_addresses" columnName="ward_code"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
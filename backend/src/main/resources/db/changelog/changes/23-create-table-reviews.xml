<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

    <changeSet id="20260426-create-reviews-table" author="zenbook">
        <createTable tableName="reviews">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="book_id" type="VARCHAR(36)">
                <constraints nullable="false" foreignKeyName="fk_reviews_book" references="books(id)" deleteCascade="true"/>
            </column>
            <column name="user_id" type="VARCHAR(36)">
                <constraints nullable="false" foreignKeyName="fk_reviews_user" references="users(id)" deleteCascade="true"/>
            </column>
            <column name="rating" type="TINYINT">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(255)"/>
            <column name="content" type="TEXT"/>
            <column name="status" type="VARCHAR(50)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="is_verified_purchase" type="BOOLEAN" defaultValueBoolean="false"/>

            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="deleted_at" type="TIMESTAMP"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
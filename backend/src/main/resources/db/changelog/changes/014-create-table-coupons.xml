<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

    <changeSet id="20260416-create-coupons" author="gemini">
        <createTable tableName="coupons">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="code" type="VARCHAR(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="discount_type" type="VARCHAR(20)"> <constraints nullable="false"/>
            </column>
            <column name="discount_value" type="DOUBLE">
                <constraints nullable="false"/>
            </column>
            <column name="max_discount_amount" type="DOUBLE"/> <column name="min_order_value" type="DOUBLE" defaultValueNumeric="0"/>
            <column name="usage_limit" type="INT"/> <column name="used_count" type="INT" defaultValueNumeric="0"/>
            <column name="max_usage_per_user" type="INT" defaultValueNumeric="1"/>

            <column name="user_id" type="VARCHAR(36)"/> <column name="category_id" type="VARCHAR(36)"/> <column name="start_date" type="DATETIME"><constraints nullable="false"/></column>
            <column name="end_date" type="DATETIME"><constraints nullable="false"/></column>
            <column name="status" type="VARCHAR(20)" defaultValue="ACTIVE"/>
            <column name="created_at" type="DATETIME" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="DATETIME"/>
            <column name="deleted_at" type="DATETIME"/>
        </createTable>
    </changeSet>
</databaseChangeLog>